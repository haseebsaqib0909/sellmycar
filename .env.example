# ─── DVLA Vehicle Enquiry Service ────────────────────────────────────────────
# Apply for a key at: https://register-for-ves.driver-vehicle-licensing.api.gov.uk
# Takes 1–2 working days. Use the UAT URL and test plates while you wait.
DVLA_API_KEY=your_dvla_api_key_here

# Test environment (use this until your live key arrives)
DVLA_API_URL=https://uat.driver-vehicle-licensing.api.gov.uk/vehicle-enquiry/v1/vehicles

# Live environment (switch to this when your live key is approved)
# DVLA_API_URL=https://driver-vehicle-licensing.api.gov.uk/vehicle-enquiry/v1/vehicles

# ─── Email ───────────────────────────────────────────────────────────────────
# Resend is recommended (free tier, simple setup): https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# Where enquiry emails are sent (the client's inbox)
EMAIL_TO=enquiries@yourdomain.co.uk

# The "from" address shown on emails (must be a verified domain in Resend)
EMAIL_FROM=noreply@yourdomain.co.uk

# ─── Site ─────────────────────────────────────────────────────────────────────
# Used for SEO canonical URLs and Open Graph metadata
NEXT_PUBLIC_SITE_URL=https://sellmycar.co.uk

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# UK mobile in international format, no plus, no spaces (e.g. 447700900000)
# Used by the floating WhatsApp button on every page
NEXT_PUBLIC_WHATSAPP_NUMBER=447700900000
